---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面不存在 | Page Not Found" description="This page could not be found">
    <main class="notfound-page">
        <div class="notfound-card">
            <div class="notfound-icon">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h1 class="notfound-title">404</h1>
            <p class="notfound-subtitle">页面不存在</p>
            <p class="notfound-subtitle-en">Page Not Found</p>
            <div class="notfound-divider"></div>
            <p class="notfound-text">你好像迷路了喵~</p>
            <p class="notfound-text-secondary">The page you are looking for does not exist or has been moved.</p>
            <a href="/" class="notfound-back">
                <i class="fa-solid fa-arrow-left"></i> 返回主页 / Back to Home
            </a>
        </div>
    </main>
</BaseLayout>

<style>
    .notfound-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 24px;
        background: var(--bg, #fffef7);
        transition: background-color 0.3s ease;
    }

    .notfound-card {
        text-align: center;
        padding: 48px 40px;
        max-width: 440px;
        width: 100%;
        background: var(--bg-card, #ffffff);
        border-radius: 24px;
        border: var(--border-width, 4px) solid var(--border-color, #0a0a0a);
        box-shadow:
            10px 10px 0 var(--fg, #0a0a0a),
            0 24px 80px rgba(0, 0, 0, 0.1);
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    [data-theme='dark'] .notfound-card {
        background: rgba(10, 10, 26, 0.6);
        border-color: rgba(255, 255, 255, 0.14);
        box-shadow:
            0 24px 80px rgba(0, 0, 0, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(24px) scale(0.97);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .notfound-icon {
        font-size: 56px;
        color: #ff5252;
        margin-bottom: 16px;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(1.08);
            opacity: 0.85;
        }
    }

    .notfound-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--fg, #0a0a0a);
        margin: 0 0 4px 0;
        letter-spacing: 0.05em;
    }

    .notfound-subtitle {
        font-family: 'Noto Sans SC', 'Space Grotesk', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--fg, #0a0a0a);
        margin: 0 0 4px 0;
    }

    .notfound-subtitle-en {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--muted, #666666);
        margin: 0 0 24px 0;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    .notfound-divider {
        width: 48px;
        height: 2px;
        background: var(--border-color, #0a0a0a);
        opacity: 0.2;
        margin: 0 auto 24px auto;
        border-radius: 1px;
    }

    .notfound-text {
        font-family: 'Noto Sans SC', sans-serif;
        font-size: 1rem;
        color: var(--fg, #0a0a0a);
        opacity: 0.7;
        margin: 0 0 8px 0;
        line-height: 1.6;
    }

    .notfound-text-secondary {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.875rem;
        color: var(--muted, #666666);
        margin: 0 0 32px 0;
    }

    .notfound-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--fg, #0a0a0a);
        opacity: 0.7;
        text-decoration: none;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 10px 24px;
        border-radius: 12px;
        border: var(--border-width, 2px) solid var(--border-color, #0a0a0a);
        transition:
            opacity 0.2s ease,
            background-color 0.2s ease,
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    .notfound-back:hover {
        opacity: 1;
        background: var(--accent-yellow, #ffe600);
        box-shadow: 4px 4px 0 var(--fg, #0a0a0a);
    }

    .notfound-back i {
        font-size: 0.85rem;
    }

    [data-theme='dark'] .notfound-back:hover {
        background: rgba(79, 195, 247, 0.15);
        box-shadow: none;
    }
</style>
